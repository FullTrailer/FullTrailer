# Samsara
SAMSARA_API_TOKEN=your_samsara_api_token_here
SAMSARA_WEBHOOK_SECRET=your_webhook_secret_base64_here

# WhatsApp Business Cloud API (Meta)
WHATSAPP_TOKEN=your_whatsapp_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
# Si es true, solo se registra en logs (no envía por la API)
WHATSAPP_DRY_RUN=true

# OpenAI (o Anthropic si se prefiere)
OPENAI_API_KEY=your_openai_key_here

# App
PORT=3000
DATABASE_URL=sqlite://fulltrailer.db

# Monitorista principal (número con código de país, sin +)
MONITOR_PHONE=521234567890

# Umbral de ausencia en días antes de alertar
ABSENCE_THRESHOLD_DAYS=3
